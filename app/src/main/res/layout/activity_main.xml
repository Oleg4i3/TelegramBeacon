<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🛡 TelegramBeacon"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#212121"
            android:layout_marginBottom="20dp" />

        <!-- Card: credentials -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:elevation="2dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bot Token"
                android:textSize="12sp"
                android:textColor="#757575" />

            <EditText
                android:id="@+id/et_token"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="123456789:ABC-xyz..."
                android:inputType="textNoSuggestions"
                android:fontFamily="monospace"
                android:textSize="14sp"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chat ID"
                android:textSize="12sp"
                android:textColor="#757575" />

            <EditText
                android:id="@+id/et_chat_id"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Ваш числовой ID (от @userinfobot)"
                android:inputType="numberSigned"
                android:fontFamily="monospace"
                android:textSize="14sp" />

        </LinearLayout>

        <!-- Card: settings -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:elevation="2dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Интервал автоотчётов (минуты)"
                android:textSize="12sp"
                android:textColor="#757575" />

            <EditText
                android:id="@+id/et_interval"
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:hint="5"
                android:inputType="number"
                android:layout_marginBottom="12dp" />

            <!-- Alarm switch row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Сигнализация при движении"
                    android:textSize="15sp"
                    android:textColor="#212121" />

                <Switch
                    android:id="@+id/sw_alarm"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true" />
            </LinearLayout>

            <!-- Auto-photo switch row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Авто-фото при тревоге"
                    android:textSize="15sp"
                    android:textColor="#212121" />

                <Switch
                    android:id="@+id/sw_auto_photo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <!-- Autostart switch row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Автозапуск при включении телефона"
                    android:textSize="15sp"
                    android:textColor="#212121" />

                <Switch
                    android:id="@+id/sw_autostart"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

        </LinearLayout>

        <!-- Toggle button -->
        <Button
            android:id="@+id/btn_toggle"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="▶  Запустить маяк"
            android:textSize="16sp"
            android:layout_marginBottom="12dp" />

        <!-- Status label -->
        <TextView
            android:id="@+id/tv_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔴 Остановлен"
            android:textSize="16sp"
            android:gravity="center"
            android:padding="8dp" />

        <!-- Hint -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="ℹ️ Chat ID: напишите /start боту @userinfobot в Telegram"
            android:textSize="12sp"
            android:textColor="#9E9E9E"
            android:gravity="center" />

    </LinearLayout>
</ScrollView>
