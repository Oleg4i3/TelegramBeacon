<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Title row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🛡 TelegramBeacon"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#212121" />

            <Button
                android:id="@+id/btn_help"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="❓ Help"
                android:textSize="13sp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp" />
        </LinearLayout>

        <!-- Card: credentials -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:elevation="2dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bot Token"
                android:textSize="12sp"
                android:textColor="#757575" />

            <EditText
                android:id="@+id/et_token"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="123456789:ABC-xyz..."
                android:inputType="textNoSuggestions"
                android:fontFamily="monospace"
                android:textSize="14sp"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chat ID"
                android:textSize="12sp"
                android:textColor="#757575" />

            <EditText
                android:id="@+id/et_chat_id"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Your numeric ID (from @userinfobot)"
                android:inputType="numberSigned"
                android:fontFamily="monospace"
                android:textSize="14sp" />

        </LinearLayout>

        <!-- Card: settings -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:elevation="2dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Auto-report interval (minutes)"
                android:textSize="12sp"
                android:textColor="#757575" />

            <EditText
                android:id="@+id/et_interval"
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:hint="5"
                android:inputType="number"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Motion alarm"
                    android:textSize="15sp"
                    android:textColor="#212121" />
                <Switch
                    android:id="@+id/sw_alarm"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Auto-photo on alarm"
                    android:textSize="15sp"
                    android:textColor="#212121" />
                <Switch
                    android:id="@+id/sw_auto_photo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Start beacon automatically on phone reboot"
                    android:textSize="15sp"
                    android:textColor="#212121" />
                <Switch
                    android:id="@+id/sw_autostart"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="GPS on-demand only (saves battery)"
                    android:textSize="15sp"
                    android:textColor="#212121" />
                <Switch
                    android:id="@+id/sw_gps_demand"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#E0E0E0" android:layout_marginTop="8dp" android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Access password (optional)"
                android:textSize="12sp"
                android:textColor="#757575" />

            <EditText
                android:id="@+id/et_password"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Leave blank = no restriction"
                android:inputType="textPassword"
                android:textSize="14sp" />

        </LinearLayout>

        <!-- Start/Stop button -->
        <Button
            android:id="@+id/btn_toggle"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="▶  Start Beacon"
            android:textSize="16sp"
            android:layout_marginBottom="10dp" />

        <!-- Status label -->
        <TextView
            android:id="@+id/tv_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔴 Stopped"
            android:textSize="16sp"
            android:gravity="center"
            android:padding="8dp"
            android:layout_marginBottom="16dp" />

        <!-- Hide icon button -->
        <Button
            android:id="@+id/btn_hide_icon"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Hide app icon"
            android:textSize="13sp"
            android:backgroundTint="#9E9E9E"
            android:layout_marginBottom="12dp" />

        <!-- Hint -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Chat ID: send /start to @userinfobot in Telegram"
            android:textSize="12sp"
            android:textColor="#BDBDBD"
            android:gravity="center" />

    </LinearLayout>
</ScrollView>
